# Database Configuration
DBHOST=localhost
DBNAME=task_manager
DBUSER=root
DBPASS=
DBPORT=3306

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long
JWT_EXPIRES_IN=12h

# Email Configuration (SMTP)
EMAILHOST=smtp.gmail.com
EMAILPORT=587
EMAILSECURE=false
EMAILUSER=your-email@gmail.com
EMAILPASS=your-app-specific-password
EMAIL_FROM=Task Manager <no-reply@gemaromatics.com>

# Application URLs
BASE_URL_API=https://api.gemaromatics.com
BASE_URL_APP=https://app.gemaromatics.com

# CORS Origins (comma-separated, supports multiple domains)
# Include: IIS domain, Firebase default domains, and custom Firebase domain
CORS_ORIGINS=https://app.gemaromatics.com,https://YOUR_FIREBASE_PROJECT_ID.web.app,https://YOUR_FIREBASE_PROJECT_ID.firebaseapp.com

# Logging
LOG_LEVEL=info

# Server Configuration
PORT=26627
NODE_ENV=production